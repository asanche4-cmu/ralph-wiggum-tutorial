#!/bin/bash
# script/db-seed - Seed database with development data
#
# Minesweeper games are ephemeral and created on demand via POST /api/games,
# so there is no meaningful seed data for the base system. This script is a
# no-op kept in place so the "Scripts to Rule Them All" interface stays
# complete and any future seedable data (e.g. the Step 2 leaderboard) has a
# home. It intentionally does not import removed models.

set -e

cd "$(dirname "$0")/.."

echo "==> No seed data required (Minesweeper games are created on demand)."
